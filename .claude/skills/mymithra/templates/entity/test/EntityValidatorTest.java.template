package {{PACKAGE_BASE}};

import {{PACKAGE_BASE}}.core.Logger;
import {{PACKAGE_BASE}}.core.ValidationResult;
import {{PACKAGE_BASE}}.core.Validator;
import {{ENTITY_MODEL_FQN}};
import {{CHILD_MODEL_FQN}};
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import static org.junit.jupiter.api.Assertions.assertFalse;
import static org.junit.jupiter.api.Assertions.assertTrue;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.same;
import static org.mockito.Mockito.never;
import static org.mockito.Mockito.verify;
import static org.mockito.Mockito.when;

@ExtendWith(MockitoExtension.class)
class {{ENTITY_NAME}}ValidatorTest {

    @Mock Validator<{{CHILD_NAME}}> {{CHILD_VAR}}Validator;
    @Mock Logger logger;

    @Test
    void shouldDelegateTo{{CHILD_NAME}}ValidatorWhenExpandedEntityPresent() {
        var sut = new {{ENTITY_NAME}}Validator(logger, {{CHILD_VAR}}Validator);
        {{CHILD_NAME}} {{CHILD_VAR}} = new {{CHILD_NAME}}();
        {{ENTITY_NAME}} input = new {{ENTITY_NAME}}();
        input.{{CHILD_SETTER}}({{CHILD_VAR}});
        when({{CHILD_VAR}}Validator.validate(any())).thenReturn(ValidationResult.ok());

        ValidationResult r = sut.validate(input);

        assertTrue(r.isValid());
        verify({{CHILD_VAR}}Validator).validate(same({{CHILD_VAR}}));
    }

    @Test
    void shouldPrefixChildErrorsWithNavigationProperty() {
        var sut = new {{ENTITY_NAME}}Validator(logger, {{CHILD_VAR}}Validator);
        {{ENTITY_NAME}} input = new {{ENTITY_NAME}}();
        input.{{CHILD_SETTER}}(new {{CHILD_NAME}}());
        when({{CHILD_VAR}}Validator.validate(any()))
            .thenReturn(ValidationResult.fail("some-field is invalid"));

        ValidationResult r = sut.validate(input);

        assertFalse(r.isValid());
        assertTrue(
            r.errors().get(0).startsWith("{{CHILD_NAV_PROPERTY}}."),
            "child error must be prefixed with the navigation property name");
    }

    @Test
    void shouldSkip{{CHILD_NAME}}ValidatorWhenExpandedEntityIsNull() {
        var sut = new {{ENTITY_NAME}}Validator(logger, {{CHILD_VAR}}Validator);
        {{ENTITY_NAME}} input = new {{ENTITY_NAME}}(); // no expanded child

        ValidationResult r = sut.validate(input);

        assertTrue(r.isValid());
        verify({{CHILD_VAR}}Validator, never()).validate(any());
    }
}

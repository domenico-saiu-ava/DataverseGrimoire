{
  "version": 1,
  "description": "Static mapping rules: regex against Dataverse attribute logical name → Datafaker provider call. First match wins. Used by the sintaura skill to override Instancio defaults with realistic values.",
  "mappings": [
    { "pattern": "^emailaddress\\d*$",                    "datafaker": "internet().emailAddress()" },
    { "pattern": "^(firstname|givenname)$",               "datafaker": "name().firstName()" },
    { "pattern": "^(lastname|surname|familyname)$",       "datafaker": "name().lastName()" },
    { "pattern": "^(fullname|name|yominame|yomifullname)$","datafaker": "name().fullName()" },
    { "pattern": "^middlename$",                          "datafaker": "name().firstName()" },
    { "pattern": "^jobtitle$",                            "datafaker": "job().title()" },
    { "pattern": "^(telephone\\d*|mobilephone|fax|pager|home(phone)?|business(phone)?|otherphone)$", "datafaker": "phoneNumber().phoneNumber()" },
    { "pattern": "^(websiteurl|url|sharepointdocumentlocationurl)$", "datafaker": "internet().url()" },
    { "pattern": "^(twitterprofile|linkedinprofile|facebook)$",       "datafaker": "internet().url()" },
    { "pattern": "^address\\d*_line\\d+$",                "datafaker": "address().streetAddress()" },
    { "pattern": "^address\\d*_(city|cityname)$",         "datafaker": "address().city()" },
    { "pattern": "^address\\d*_country$",                 "datafaker": "address().country()" },
    { "pattern": "^address\\d*_(postalcode|postcode|zipcode)$", "datafaker": "address().zipCode()" },
    { "pattern": "^address\\d*_(stateorprovince|state|county)$", "datafaker": "address().state()" },
    { "pattern": "^(companyname|accountname|parentaccountname|parentcustomername)$", "datafaker": "company().name()" },
    { "pattern": "^industrycode$",                        "datafaker": "company().industry()" },
    { "pattern": "^description$",                         "datafaker": "lorem().paragraph()" },
    { "pattern": "^subject$",                             "datafaker": "lorem().sentence()" },
    { "pattern": "^location$",                            "datafaker": "address().fullAddress()" },
    { "pattern": "^(statecode|statuscode)$",              "datafaker": "options().option(\"Open\", \"Completed\", \"Canceled\", \"Active\", \"Inactive\", \"Scheduled\")" },
    { "pattern": "^.*id$",                                "datafaker": "internet().uuid()" },
    { "pattern": "^(versionnumber|importsequencenumber)$","datafaker": "number().numberBetween(1L, 1000L)" },
    { "pattern": "^(scheduled|actual)(start|end)$",       "datafaker": "date().future(60, java.util.concurrent.TimeUnit.DAYS).toInstant().atOffset(java.time.ZoneOffset.UTC)" },
    { "pattern": "^(createdon|modifiedon|overriddencreatedon)$", "datafaker": "date().past(365, java.util.concurrent.TimeUnit.DAYS).toInstant().atOffset(java.time.ZoneOffset.UTC)" },
    { "pattern": "^.+on$",                                "datafaker": "date().past(180, java.util.concurrent.TimeUnit.DAYS).toInstant().atOffset(java.time.ZoneOffset.UTC)" },
    { "pattern": "^.+date$",                              "datafaker": "date().past(180, java.util.concurrent.TimeUnit.DAYS).toInstant().atOffset(java.time.ZoneOffset.UTC)" },
    { "pattern": "^(creditlimit|revenue|estimatedvalue|actualvalue|totalamount|amount|price|cost)$", "datafaker": "commerce().price().replace(',', '.')" },
    { "pattern": "^(numberof.*|.*count)$",                "datafaker": "number().numberBetween(0L, 100L)" }
  ]
}
